@model FinalProject.Models.Mod

<h2>@Model.Name</h2>

<div>
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Author:</strong> @Model.Author</p>
    <p><strong>Release Date:</strong> @Model.ReleaseDate.ToShortDateString()</p>
    <a href="~/modfiles/@Model.FileName" target="_blank">
        Download Mod File
    </a>
</div>

<a asp-controller="Mods" asp-action="Index">Back to Mods</a>